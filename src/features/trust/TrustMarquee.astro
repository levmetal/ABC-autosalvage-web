---
import { ShieldCheck, Star, Banknote, Truck } from 'lucide-react';
---

<div class="w-full bg-[var(--color-base-surface)] border-y border-white/5 py-4 overflow-hidden relative flex opacity-90">
  
  {/* Gradient masks for smooth fade at edges */}
  <div class="absolute inset-y-0 left-0 w-24 bg-gradient-to-r from-[var(--color-base-surface)] to-transparent z-10"></div>
  <div class="absolute inset-y-0 right-0 w-24 bg-gradient-to-l from-[var(--color-base-surface)] to-transparent z-10"></div>

  <div class="flex whitespace-nowrap animate-marquee items-center">
    {/* First set */}
    <div class="flex items-center gap-12 px-6">
      <div class="flex items-center gap-2 text-gray-400 font-medium whitespace-nowrap">
        <div class="flex text-yellow-500">
           <Star class="w-5 h-5 fill-current" />
           <Star class="w-5 h-5 fill-current" />
           <Star class="w-5 h-5 fill-current" />
           <Star class="w-5 h-5 fill-current" />
           <Star class="w-5 h-5 fill-current" />
        </div>
        <span class="text-white ml-2">4.9/5 Trustpilot Rating</span>
      </div>
      <div class="w-1 h-1 rounded-full bg-white/20"></div>
      
      <div class="flex items-center gap-2 text-gray-300 font-medium whitespace-nowrap">
        <ShieldCheck class="w-5 h-5 text-[var(--color-accent-blue)]" />
        Licensed & Insured Dealer
      </div>
      <div class="w-1 h-1 rounded-full bg-white/20"></div>

      <div class="flex items-center gap-2 text-gray-300 font-medium whitespace-nowrap">
        <Banknote class="w-5 h-5 text-[var(--color-accent-blue)]" />
        Zero Hidden Fees
      </div>
      <div class="w-1 h-1 rounded-full bg-white/20"></div>

      <div class="flex items-center gap-2 text-gray-300 font-medium whitespace-nowrap">
        <Truck class="w-5 h-5 text-[var(--color-accent-blue)]" />
        100% Free Nationwide Towing
      </div>
    </div>
    
    {/* Duplicated set for seamless loop */}
    <div class="flex items-center gap-12 px-6">
      <div class="flex items-center gap-2 text-gray-400 font-medium whitespace-nowrap">
        <div class="flex text-yellow-500">
           <Star class="w-5 h-5 fill-current" />
           <Star class="w-5 h-5 fill-current" />
           <Star class="w-5 h-5 fill-current" />
           <Star class="w-5 h-5 fill-current" />
           <Star class="w-5 h-5 fill-current" />
        </div>
        <span class="text-white ml-2">4.9/5 Trustpilot Rating</span>
      </div>
      <div class="w-1 h-1 rounded-full bg-white/20"></div>
      
      <div class="flex items-center gap-2 text-gray-300 font-medium whitespace-nowrap">
        <ShieldCheck class="w-5 h-5 text-[var(--color-accent-blue)]" />
        Licensed & Insured Dealer
      </div>
      <div class="w-1 h-1 rounded-full bg-white/20"></div>

      <div class="flex items-center gap-2 text-gray-300 font-medium whitespace-nowrap">
        <Banknote class="w-5 h-5 text-[var(--color-accent-blue)]" />
        Zero Hidden Fees
      </div>
      <div class="w-1 h-1 rounded-full bg-white/20"></div>

      <div class="flex items-center gap-2 text-gray-300 font-medium whitespace-nowrap">
        <Truck class="w-5 h-5 text-[var(--color-accent-blue)]" />
        100% Free Nationwide Towing
      </div>
    </div>
  </div>
</div>

<style>
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .animate-marquee {
    animation: marquee 20s linear infinite;
  }
</style>
