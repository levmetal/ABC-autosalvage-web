---
import '../styles/global.css';
import { getImage } from 'astro:assets';
import appleIconAsset from '../assets/images/branding/apple-touch-icon.png';
import favicon192Asset from '../assets/images/branding/favicon-192.png';

interface Props {
	title: string;
	description?: string;
	image?: string;
	url?: string;
}

const { 
	title, 
	description = "Turn your non-running or wrecked vehicle into instant cash. ABC Autosalvage offers top dollar, professional recovery, and free towing across North Carolina. No hidden fees — just fast, honest service.", 
	image = "/og-image.jpg",
	url = "https://abc-autosalvage.com"
} = Astro.props;

// Optimize Branding Icons (Compression from 468KB to ~20KB)
const optimizedAppleIcon = await getImage({ src: appleIconAsset, width: 180, height: 180, format: 'png', quality: 'high' });
const optimizedFavicon192 = await getImage({ src: favicon192Asset, width: 192, height: 192, format: 'png', quality: 'high' });

const siteUrl = import.meta.env.SITE || "https://abc-autosalvage.com";
const canonicalUrl = url ? `${siteUrl}${url}` : siteUrl;
const imageUrl = image && image.startsWith('http') ? image : image ? `${siteUrl}${image}` : "";

const businessSchema = {
  "@context": "https://schema.org",
  "@type": "AutoDealer",
  "name": "ABC Autosalvage",
  "alternateName": "ABC Auto Salvage",
  "image": imageUrl,
  "url": siteUrl,
  "telephone": "+1-919-437-8198",
  "email": "Angel@abc-autosalvage.com",
  "description": "We buy vehicles in any condition — wrecked, running, high mileage, or non-starting. Free towing and same-day cash payment across North Carolina.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "4417 US-70 BUS",
    "addressLocality": "Clayton",
    "addressRegion": "NC",
    "postalCode": "27520",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 35.6558,
    "longitude": -78.4554
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "08:00",
      "closes": "18:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Saturday",
      "opens": "09:00",
      "closes": "14:00"
    }
  ],
  "priceRange": "$$",
  "areaServed": {
    "@type": "State",
    "name": "North Carolina"
  },
  "sameAs": [],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Vehicle Purchase Services",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Cash for Wrecked Cars"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Cash for Non-Running Vehicles"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Cash for High Mileage Cars"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Free Vehicle Towing"
        }
      }
    ]
  }
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "ABC Autosalvage",
  "url": siteUrl,
  "potentialAction": {
    "@type": "SearchAction",
    "target": `${siteUrl}/?q={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "ABC Autosalvage",
  "image": imageUrl,
  "telephone": "+1-919-437-8198",
  "email": "Angel@abc-autosalvage.com",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "4417 US-70 BUS",
    "addressLocality": "Clayton",
    "addressRegion": "NC",
    "postalCode": "27520",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 35.6558,
    "longitude": -78.4554
  },
  "url": siteUrl,
  "priceRange": "$$"
};
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=3" />
		<link rel="icon" type="image/png" sizes="192x192" href={optimizedFavicon192.src} />
		<link rel="apple-touch-icon" href={optimizedAppleIcon.src} />
		<link rel="shortcut icon" href="/favicon.ico?v=3" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Canonical URL -->
		<link rel="canonical" href={canonicalUrl} />

		<!-- ==================== OPEN GRAPH (Facebook, LinkedIn, etc.) ==================== -->
		<meta property="og:type" content="website" />
		<meta property="og:locale" content="en_US" />
		<meta property="og:site_name" content="ABC Autosalvage" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		{imageUrl && <meta property="og:image" content={imageUrl} />}
		{imageUrl && <meta property="og:image:width" content="1200" />}
		{imageUrl && <meta property="og:image:height" content="630" />}
		{imageUrl && <meta property="og:image:alt" content="ABC Autosalvage - Cash for Cars in North Carolina" />}

		<!-- ==================== TWITTER CARD ==================== -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		{imageUrl && <meta name="twitter:image" content={imageUrl} />}

		<!-- ==================== AI INDEXING (ChatGPT, Gemini, Perplexity) ==================== -->
		<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
		<meta name="googlebot" content="index, follow" />
		
		<!-- AI-specific metadata for LLM crawlers -->
		<meta name="author" content="ABC Autosalvage" />
		<meta name="keywords" content="cash for cars North Carolina, junk car buyer Clayton NC, sell my car fast, wrecked car buyer, free car towing North Carolina, ABC Autosalvage, scrap car cash, auto salvage NC, we buy cars any condition, cash for junk cars near me" />

		<!-- ==================== GEO TARGETING ==================== -->
		<meta name="geo.region" content="US-NC" />
		<meta name="geo.placename" content="Clayton" />
		<meta name="geo.position" content="35.6558;-78.4554" />
		<meta name="ICBM" content="35.6558, -78.4554" />
		
		<!-- Custom Fonts from Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@800;900&family=Roboto:wght@400;500&display=swap" rel="stylesheet">
		
		<title>{title}</title>

		<script is:inline type="application/ld+json" set:html={JSON.stringify(businessSchema)} />
		<script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
		<script is:inline type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
	</head>
	<body class="bg-[var(--color-base)] text-white overflow-x-hidden antialiased selection:bg-[var(--color-primary)] selection:text-black">
		<slot />

		<script>
			// Initialize GSAP ScrollTrigger and Lenis across the app
			import { initLenis } from '../utils/lenis-manager';
			import gsap from 'gsap';
			import { ScrollTrigger } from 'gsap/ScrollTrigger';

			gsap.registerPlugin(ScrollTrigger);
			initLenis();

			// Sync GSAP with Lenis
			// When Lenis runs, it updates the window scroll position, ScrollTrigger needs to update.
			import { lenis } from '../utils/lenis-manager';
			
			if (lenis) {
				lenis.on('scroll', ScrollTrigger.update);
				gsap.ticker.add((time)=>{
				  lenis?.raf(time * 1000)
				})
				gsap.ticker.lagSmoothing(0)
			}
		</script>
	</body>
</html>
